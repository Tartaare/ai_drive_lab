<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Simple Car - Experience de Conduite</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@200;400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="src/css/style.css">
</head>
<body>
    <!-- Loading Screen -->
    <div id="loading" class="overlay">
        <div class="menu-content">
            <h1 class="menu-title" style="font-size: 2rem; margin-bottom: 2rem;">Simple Car ML</h1>
            <div class="loader-spinner"></div>
            <p style="margin-top: 20px; color: var(--text-secondary); font-size: 0.9rem;">Initialisation du moteur physique...</p>
        </div>
    </div>

    <!-- Main Menu -->
    <div id="main-menu" class="overlay hidden">
        <div class="menu-content">
            <h1 class="menu-title">SIMPLE CAR</h1>
            <p class="menu-subtitle">SIMULATION PHYSIQUE & CONDUITE</p>
            
            <div class="menu-actions">
                <div class="setting-group" style="width: 100%; text-align: left; margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 8px;">SÉLECTION DU CIRCUIT</label>
                    <select id="main-menu-level-select" style="width: 100%;">
                        <option value="default">Circuit Classique</option>
                        <option value="procedural">Circuit Procédural (Infini)</option>
                    </select>
                </div>
                <button id="start-game" class="btn" style="width: 100%;">DÉMARRER LA SESSION</button>
            </div>
        </div>
    </div>

    <!-- Pause Menu -->
    <div id="pause-overlay" class="overlay hidden">
        <div class="menu-content">
            <h1 class="menu-title" style="font-size: 3rem;">PAUSE</h1>
            <div class="menu-actions">
                <button id="resume-game" class="btn" style="min-width: 200px;">REPRENDRE</button>
                <button id="back-to-menu" class="btn btn-secondary" style="min-width: 200px;">QUITTER</button>
            </div>
        </div>
    </div>

    <!-- HUD Layer -->
    <div id="hud-layer" class="hud-layer hidden-ui">
        
        <!-- Top Left: Procedural Controls -->
        <div class="hud-top-left">
            <div id="procedural-controls" class="panel proc-settings hidden-ui">
                <div class="controls-header" id="toggle-proc-panel">
                    <h3 style="font-size: 12px; font-weight: 600; letter-spacing: 1px;">CONFIG CIRCUIT</h3>
                    <span style="font-size: 10px; opacity: 0.5;">▼</span>
                </div>
                <div id="procedural-content" class="proc-content">
                    <button id="proc-regenerate" class="btn btn-secondary" style="width: 100%; padding: 8px; margin-bottom: 16px; font-size: 11px;">GÉNÉRER NOUVEAU</button>
                    
                    <div class="setting-group">
                        <div class="setting-header">
                            <span>Points de contrôle</span>
                            <span id="proc-numControlPoints-value">-</span>
                        </div>
                        <input id="proc-numControlPoints" type="range" min="6" max="20" step="1" value="12">
                    </div>

                    <div class="setting-group">
                        <div class="setting-header"><span>Rayon de base</span><span id="proc-baseRadius-value">-</span></div>
                        <input id="proc-baseRadius" type="range" min="30" max="150" step="1" value="50">
                    </div>

                    <div class="setting-group">
                        <div class="setting-header"><span>Var. Rayon</span><span id="proc-radiusVariation-value">-</span></div>
                        <input id="proc-radiusVariation" type="range" min="0" max="100" step="1" value="40">
                    </div>

                    <div class="setting-group">
                        <div class="setting-header"><span>Var. Angle</span><span id="proc-angleVariation-value">-</span></div>
                        <input id="proc-angleVariation" type="range" min="0" max="100" step="1" value="30">
                    </div>

                    <div class="setting-group">
                        <div class="setting-header"><span>Largeur</span><span id="proc-trackWidth-value">-</span></div>
                        <input id="proc-trackWidth" type="range" min="5" max="30" step="1" value="10">
                    </div>
                </div>
            </div>
        </div>

        <!-- Top Right: Level Selector Info -->
        <div class="hud-top-right">
             <div class="panel" style="padding: 8px 16px;">
                <select id="level-select" style="background: transparent; border: none; font-size: 12px; text-align: right; width: auto; color: var(--text-secondary);">
                    <option value="default">Circuit Classique</option>
                    <option value="procedural">Circuit Procédural</option>
                </select>
             </div>
        </div>

        <!-- Bottom Left: Controls -->
        <div class="hud-bottom-left">
            <div id="controls-container" class="panel controls-panel">
                <div class="controls-header" id="toggle-controls">
                    <h3 style="font-size: 12px; font-weight: 600; letter-spacing: 1px;">COMMANDES</h3>
                    <span style="font-size: 10px; opacity: 0.5;">▼</span>
                </div>
                <div id="controls-content" class="controls-list">
                    <div class="control-row">
                        <span>Avancer / Freiner</span>
                        <div><span class="key-badge">W</span> <span class="key-badge">S</span></div>
                    </div>
                    <div class="control-row">
                        <span>Direction</span>
                        <div><span class="key-badge">A</span> <span class="key-badge">D</span></div>
                    </div>
                    <div class="control-row">
                        <span>Frein à main</span>
                        <span class="key-badge" style="width: auto; min-width: 60px;">ESPACE</span>
                    </div>
                    <div class="control-row">
                        <span>Reset</span>
                        <span class="key-badge">R</span>
                    </div>
                    <div class="control-row">
                        <span>Caméra</span>
                        <span class="key-badge" style="width: auto;">SOURIS</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom Right: Telemetry -->
        <div class="hud-bottom-right">
            <div id="telemetry" class="telemetry-container">
                <div class="t-group">
                    <div class="t-label">RAPP.</div>
                    <div class="gear-display" id="gear-value">N</div>
                </div>
                <div class="t-group">
                    <div class="t-label">KM/H</div>
                    <div class="t-value-huge" id="speed-value">0</div>
                </div>
                <div class="t-group" style="opacity: 0.7;">
                    <div class="t-label">RPM</div>
                    <div style="font-family: var(--font-mono); font-size: 20px; font-weight: 400;" id="rpm-value">0</div>
                </div>
            </div>
        </div>
    </div>

    <script src="build/simple_car.min.js"></script>
    <script>
        // --- Game Logic & UI Binding ---
        let world = null;
        let gameStarted = false;

        // UI Elements
        const loadingEl = document.getElementById('loading');
        const mainMenuEl = document.getElementById('main-menu');
        const hudLayer = document.getElementById('hud-layer');
        const pauseOverlay = document.getElementById('pause-overlay');
        
        // Buttons
        const startButton = document.getElementById('start-game');
        const resumeButton = document.getElementById('resume-game');
        const backToMenuButton = document.getElementById('back-to-menu');
        
        // Inputs
        const mainMenuLevelSelect = document.getElementById('main-menu-level-select');
        const inGameLevelSelect = document.getElementById('level-select');
        
        // Procedural UI
        const proceduralPanel = document.getElementById('procedural-controls');
        const proceduralContent = document.getElementById('procedural-content');
        const procToggleBtn = document.getElementById('toggle-proc-panel');
        const procRegenerateBtn = document.getElementById('proc-regenerate');
        
        // Procedural Sliders
        const procInputs = {
            numControlPoints: document.getElementById('proc-numControlPoints'),
            baseRadius: document.getElementById('proc-baseRadius'),
            radiusVariation: document.getElementById('proc-radiusVariation'),
            angleVariation: document.getElementById('proc-angleVariation'),
            trackWidth: document.getElementById('proc-trackWidth')
        };
        const procValues = {
            numControlPoints: document.getElementById('proc-numControlPoints-value'),
            baseRadius: document.getElementById('proc-baseRadius-value'),
            radiusVariation: document.getElementById('proc-radiusVariation-value'),
            angleVariation: document.getElementById('proc-angleVariation-value'),
            trackWidth: document.getElementById('proc-trackWidth-value')
        };

        // --- Helper Functions ---

        function refreshProceduralUIFromWorld() {
            if (!world || typeof world.getProceduralConfig !== 'function') return;
            const cfg = world.getProceduralConfig();

            if (procInputs.numControlPoints) {
                procInputs.numControlPoints.value = cfg.numControlPoints;
                procValues.numControlPoints.textContent = cfg.numControlPoints;
            }
            if (procInputs.baseRadius) {
                procInputs.baseRadius.value = cfg.baseRadius;
                procValues.baseRadius.textContent = cfg.baseRadius;
            }
            if (procInputs.radiusVariation) {
                const v = Math.round(cfg.radiusVariation * 100);
                procInputs.radiusVariation.value = v;
                procValues.radiusVariation.textContent = v + '%';
            }
            if (procInputs.angleVariation) {
                const v = Math.round(cfg.angleVariation * 100);
                procInputs.angleVariation.value = v;
                procValues.angleVariation.textContent = v + '%';
            }
            if (procInputs.trackWidth) {
                procInputs.trackWidth.value = cfg.trackWidth;
                procValues.trackWidth.textContent = cfg.trackWidth;
            }
        }

        function togglePanel(panel, content) {
            if (!panel) return;
            // The content hiding is handled by CSS .collapsed selector based on parent state
            panel.classList.toggle('collapsed');
        }

        // --- Event Listeners ---

        // 1. Procedural Panel Toggle
        if (procToggleBtn) {
            procToggleBtn.addEventListener('click', () => {
                togglePanel(proceduralPanel, null); 
            });
        }

        // 2. Controls Toggle
        const controlsHeader = document.getElementById('toggle-controls');
        const controlsPanel = document.getElementById('controls-container');
        if (controlsHeader) {
            controlsHeader.addEventListener('click', () => {
                togglePanel(controlsPanel, null);
            });
        }

        // 3. Start Game
        if (startButton) {
            startButton.addEventListener('click', () => {
                if (gameStarted) return;
                gameStarted = true;

                // UI Transition
                mainMenuEl.classList.add('hidden');
                hudLayer.classList.remove('hidden-ui');
                hudLayer.classList.add('fade-enter');

                // Init World
                let initialLevel = mainMenuLevelSelect ? mainMenuLevelSelect.value : 'default';
                
                // If world already exists (shouldn't happen here but safe guard)
                if (world) {
                     if (typeof world.dispose === 'function') world.dispose();
                }

                world = new SimpleCar.World('car_models/car_blue.glb', initialLevel);

                // Sync In-Game Select
                if (inGameLevelSelect) inGameLevelSelect.value = initialLevel;

                // Handle Procedural UI Visibility
                if (proceduralPanel) {
                    if (initialLevel === 'procedural') {
                        proceduralPanel.classList.remove('hidden-ui');
                        // Give a moment for world to init config
                        setTimeout(refreshProceduralUIFromWorld, 100);
                    } else {
                        proceduralPanel.classList.add('hidden-ui');
                    }
                }
            });
        }

        // 4. Resume Game
        if (resumeButton) {
            resumeButton.addEventListener('click', () => {
                if (world && typeof world.resume === 'function') {
                    world.resume();
                }
                pauseOverlay.classList.add('hidden');
            });
        }

        // 5. Back to Menu
        if (backToMenuButton) {
            backToMenuButton.addEventListener('click', () => {
                if (world && typeof world.dispose === 'function') {
                    world.dispose();
                }
                world = null;
                gameStarted = false;

                pauseOverlay.classList.add('hidden');
                hudLayer.classList.add('hidden-ui');
                hudLayer.classList.remove('fade-enter');
                
                mainMenuEl.classList.remove('hidden');

                // Reset specific displays
                const speedVal = document.getElementById('speed-value');
                if (speedVal) speedVal.textContent = '0';
            });
        }

        // 6. Level Select Change (In-Game)
        if (inGameLevelSelect) {
            inGameLevelSelect.addEventListener('change', (e) => {
                if (world && typeof world.setLevel === 'function') {
                    world.setLevel(e.target.value);
                }
                inGameLevelSelect.blur();

                if (proceduralPanel) {
                    if (e.target.value === 'procedural') {
                        proceduralPanel.classList.remove('hidden-ui');
                        refreshProceduralUIFromWorld();
                    } else {
                        proceduralPanel.classList.add('hidden-ui');
                    }
                }
            });
        }

        // 7. Procedural Inputs
        if (procRegenerateBtn) {
            procRegenerateBtn.addEventListener('click', () => {
                if (world && typeof world.randomizeProceduralSeed === 'function') {
                    world.randomizeProceduralSeed();
                    refreshProceduralUIFromWorld();
                }
                procRegenerateBtn.blur();
            });
        }

        // Helper to bind slider
        function bindSlider(input, display, paramName, scale = 1, isInt = true) {
            if (input) {
                input.addEventListener('input', () => {
                    if (world && typeof world.setProceduralParameter === 'function') {
                        let val = parseFloat(input.value);
                        if (isInt) val = parseInt(input.value, 10);
                        
                        // Update World
                        // Note: paramName matches the internal config keys
                        // For variation (0-100) we need to divide by 100 for the world param if needed
                        let worldVal = val;
                        if (scale !== 1) worldVal = val / scale;

                        world.setProceduralParameter(paramName, worldVal);
                        
                        // Update Display
                        if (display) {
                            if (scale === 100) display.textContent = val + '%';
                            else display.textContent = val;
                        }
                    }
                });
            }
        }

        bindSlider(procInputs.numControlPoints, procValues.numControlPoints, 'numControlPoints');
        bindSlider(procInputs.baseRadius, procValues.baseRadius, 'baseRadius');
        bindSlider(procInputs.radiusVariation, procValues.radiusVariation, 'radiusVariation', 100);
        bindSlider(procInputs.angleVariation, procValues.angleVariation, 'angleVariation', 100);
        bindSlider(procInputs.trackWidth, procValues.trackWidth, 'trackWidth');


        // --- Telemetry Loop ---
        setInterval(() => {
            if (!world || !world.car) return;
            const speedEl = document.getElementById('speed-value');
            const gearEl = document.getElementById('gear-value');
            const rpmEl = document.getElementById('rpm-value');

            if (speedEl) {
                const speedKmh = Math.abs(Math.round(world.car.speed * 3.6));
                speedEl.textContent = String(speedKmh);
            }

            if (gearEl) {
                const gear = world.car.currentGear;
                let gearDisplay = gear;
                if (gear === 0) gearDisplay = 'N';
                if (gear === undefined) gearDisplay = '-';
                // Simple heuristic for reverse text
                if (world.car.speed < -0.1 && world.car.currentGear <= 0) gearDisplay = 'R'; 
                gearEl.textContent = String(gearDisplay);
            }

            if (rpmEl) {
                 // Simplified RPM simulation for visual flair
                 // Assuming SimpleCar exposes speed or we derive it
                 const speedAbs = Math.abs(world.car.speed);
                 // Mock values if not exposed directly
                 const idleRpm = 900;
                 const redlineRpm = 7500;
                 // Very rough gear ratios
                 const gearMaxSpeeds = { R: 4, 0: 0, 1: 5, 2: 9, 3: 13, 4: 17, 5: 22 };
                 let maxSpeed = gearMaxSpeeds[String(world.car.currentGear)] || 20;
                 if (world.car.speed < -0.1) maxSpeed = 5;

                 const ratio = maxSpeed > 0 ? Math.min(speedAbs / maxSpeed, 1) : 0;
                 // Add some noise/wobble
                 const noise = Math.random() * 50;
                 const rpm = Math.round(idleRpm + (ratio * (redlineRpm - idleRpm)) + noise);
                 
                 rpmEl.textContent = rpm;
            }

            // Check for pause state externally if needed, 
            // but usually the game loop handles logic. 
            // If the user presses ESC, world might trigger a callback?
            // Existing implementation didn't seem to have a callback back to UI for pause.
            // We'll rely on global keydown for ESC to toggle pause menu if World doesn't handle it.
        }, 50);

        // Global Key Listener for Pause (ESC)
        window.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && gameStarted) {
                // Toggle Pause
                const isPaused = !pauseOverlay.classList.contains('hidden');
                if (isPaused) {
                    // Resume
                    if (world && world.resume) world.resume();
                    pauseOverlay.classList.add('hidden');
                } else {
                    // Pause
                    if (world && world.pause) world.pause(); 
                    pauseOverlay.classList.remove('hidden');
                }
            }
        });

        // Hide loading after a simulated delay (or real load)
        window.addEventListener('load', () => {
            setTimeout(() => {
                loadingEl.classList.add('hidden');
                mainMenuEl.classList.remove('hidden');
            }, 1000);
        });

    </script>
</body>
</html>
