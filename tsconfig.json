{
    "include": [
        "src/ts/**/*",
        "vite.config.mts"
    ],
    "exclude": [
        "node_modules"
    ],
    "compilerOptions": {
        "module": "ESNext",
        "target": "ES2020",
        "lib": ["DOM", "DOM.Iterable", "ES2020"],
        "jsx": "react-jsx",
        "moduleResolution": "node",
        "declaration": false,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "noEmit": true,
        "rootDir": ".",
        "baseUrl": ".",
        "skipLibCheck": true,
        "paths": {
            "cannon" : ["src/lib/cannon/cannon"]
        }
    }
}
